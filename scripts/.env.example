# CleverTap API Credentials
# Find these in: CleverTap Dashboard → Settings → Integration → API Credentials
CLEVERTAP_ACCOUNT_ID=your-account-id
CLEVERTAP_PASSCODE=your-passcode

# Jira Credentials
# API token: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=your@email.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=CRM

# Team member Jira account IDs (find in Jira profile URL)
JIRA_USER_MINH=minh-jira-account-id
JIRA_USER_LINH=linh-jira-account-id
JIRA_USER_DUC=duc-jira-account-id
